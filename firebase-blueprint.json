{
  "entities": {
    "BusLocation": {
      "title": "Bus Location",
      "description": "Real-time location of a bus or contributor",
      "type": "object",
      "properties": {
        "busId": { "type": "string", "description": "Unique ID for the bus/device" },
        "routeId": { "type": "string", "description": "ID of the route being followed" },
        "lat": { "type": "number", "description": "Latitude" },
        "lng": { "type": "number", "description": "Longitude" },
        "speed": { "type": "number", "description": "Current speed in km/h" },
        "lastUpdate": { "type": "number", "description": "Timestamp of last update" }
      },
      "required": ["busId", "routeId", "lat", "lng", "speed", "lastUpdate"]
    }
  },
  "firestore": {
    "/bus_locations/{busId}": {
      "schema": "BusLocation",
      "description": "Collection of active bus locations"
    }
  }
}
